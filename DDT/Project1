import Utilities
import time
from selenium import webdriver
driver=webdriver.Chrome()
driver.implicitly_wait(10)
driver.get(r"https://practicetestautomation.com/practice-test-login/")
driver.maximize_window()
time.sleep(2)
path=r"C:\Users\\Desktop\Python Projects\DDT.xlsx"
rows=Utilities.get_row_count(path,"Sheet1")
for r in range(2,rows+1):
    UN=Utilities.read_data(path,"Sheet1",r,1)
    PWD = Utilities.read_data(path, "Sheet1", r, 2)
    driver.find_element("id","username").send_keys(UN)
    time.sleep(1)
    driver.find_element("id","password").send_keys(PWD)
    time.sleep(1)
    driver.find_element("id","submit").click()
    time.sleep(2)
    if driver.current_url == "":
        print("test is passed")
        Utilities.write_data(path, "Sheet1", r, 4, "pass")
        driver.back()
        driver.refresh()
    else:
        print("test is failed")
        Utilities.write_data(path, "Sheet1", r, 4, "fail")
    time.sleep(2)
time.sleep(3)




























































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































class HOME:
    practice='//a[@href="https://practicetestautomation.com/practice/"]'
    logout='//a[@href="https://practicetestautomation.com/practice-test-login/"]'

    def __init__(self,driver):
        self.driver=driver

    def click_practice(self):
        self.driver.find_element('xpath',self.practice).click()

    def click_logout(self):
        self.driver.find_element('xpath',self.logout).click()



import time
from selenium import webdriver
from selenium.webdriver import ActionChains
driver=webdriver.Chrome()
driver.implicitly_wait(10)
driver.get("https://demoapps.qspiders.com/ui/dragDrop?sublist=0")
driver.maximize_window()
time.sleep(2)
ob=ActionChains(driver)
default_ele=driver.find_element('xpath',"//div[text()='Drag Me']")
ob.drag_and_drop_by_offset(default_ele,0,200).perform()
time.sleep(2)

default_ele1=driver.find_element('xpath',"//div[text()='Drag Me']")
ob.drag_and_drop_by_offset(default_ele1,0,-200).perform()
time.sleep(2)

default_ele2=driver.find_element('xpath',"//div[text()='Drag Me']")
ob.drag_and_drop_by_offset(default_ele2,300,0).perform()
time.sleep(2)

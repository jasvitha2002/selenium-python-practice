import time
from selenium import webdriver
driver=webdriver.Chrome()
driver.get("https://testautomationpractice.blogspot.com/")
driver.maximize_window()
time.sleep(2)

rad_buttons=driver.find_elements('xpath',"//input[@type='radio']")
print(len(rad_buttons))

for i in rad_buttons:
    if i.get_attribute('id')=='male':
        i.click()
        break


checkboxes=driver.find_elements('xpath',"//input[@type='checkbox']")
print(len(checkboxes))


days=driver.find_elements('xpath',"//input[@type='checkbox' and @class]")
print(len(days))

for i in days:
    i.click()
    time.sleep(3)

for i in days[::-1]:
    i.click()
    time.sleep(1)

for i in days[:3:]:
    i.click()

for i in days:
    if i.get_attribute('id') in ['saturday','tuesday']:
        i.click()
        time.sleep(4)



#screenshot of particular element

import time
from selenium import webdriver
driver=webdriver.Chrome()
driver.get("https://testautomationpractice.blogspot.com/")
driver.maximize_window()
time.sleep(2)
text_box=driver.find_element('id','name')
button=driver.find_element('name', 'start')
text_box.screenshot("text_box.png")
button.screenshot("button.png")
time.sleep(3)


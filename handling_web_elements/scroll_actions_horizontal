import time
from selenium import webdriver
from selenium.webdriver import ActionChains
driver=webdriver.Chrome()

driver.get("https://demoapps.qspiders.com/ui/scroll/newTabHorizontal/")
driver.maximize_window()
time.sleep(2)
ob=ActionChains(driver)

ob.scroll_by_amount(1000,0).perform()
time.sleep(2)

driver.execute_script('window.scrollBy(document.body.scrollWidth,0)')
time.sleep(2)

# driver.execute_script('window.scrollBy(-document.body.scrollWidth,0)')
# time.sleep(2)

x_axis_val=driver.execute_script("return window.pageXOffset;")
print(x_axis_val)

driver.execute_script('window.scrollBy(1700,0)')
time.sleep(2)








